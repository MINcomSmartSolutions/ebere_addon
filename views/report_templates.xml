<?xml version="1.0" encoding="utf-8"?>
<!-- CAUTION: This file customizes the DIN5008 invoice PDF layout.
     It relies on DeltaBillingSystem and its inputs with indexes.
     Customization is for language DE. May cause irregularities with EN. -->
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- Invoice document: Inherit account.report_invoice_document    -->
        <!-- Adds billing period, German headers, custom line rendering   -->
        <!-- ============================================================ -->
        <template id="report_invoice_document_custom"
                  inherit_id="account.report_invoice_document">

            <xpath expr="//div[hasclass('mt-5', 'clearfix')]" position="before">
                <div style="margin-left: 5mm">
                    <div t-if="o and o.billing_period_start and o.billing_period_end">
                        <span>Für die Rechnungsperiode vom&#160;</span>
                        <span t-field="o.billing_period_start"
                              t-options='{"widget": "date","tz_name": "Europe/Berlin","format": "dd.MM.yyyy"}'/>
                        bis
                        <span t-field="o.billing_period_end"
                              t-options='{"widget": "date","tz_name": "Europe/Berlin","format": "dd.MM.yyyy"}'/>
                    </div>
                    <div t-if="o and o.invoice_date">
                        <span>Erstellt am&#160;</span>
                        <span t-field="o.invoice_date"
                              t-options='{"widget": "date","tz_name": "Europe/Berlin","format": "dd.MM.yyyy"}'/>
                    </div>
                </div>
            </xpath>


            <xpath expr="//th[@name='th_priceunit']/span" position="replace">
                <span>Stückpreis</span>
            </xpath>
            <xpath expr="//th[@name='th_taxes']" position="attributes">
                <attribute name="t-attf-class">text-start {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}</attribute>
            </xpath>
<!--            <xpath expr="//th[@name='th_taxes']/span" position="replace">-->
<!--                <span>MwSt.</span>-->
<!--            </xpath>-->
            <!-- <xpath expr="//th[@name='th_subtotal']/span" position="replace">
                <span>Gesamt Netto</span>
            </xpath> -->

            <!-- Custom line name: product_id.name (bold) + product-specific annotations -->
            <xpath expr="//td[@name='account_invoice_line_name']" position="replace">
                <td name="account_invoice_line_name">
                    <strong t-if="line.product_id.name"
                            t-field="line.product_id.name"
                            t-options="{'widget': 'text'}"/>
                    <t t-if="line.product_id.default_code in ('fixed_price', 'grundpreis_liefer_vertrag')">
                        <span style="line-height: 1.5">(abgerechnet im Liefervertrag)</span>
                    </t>
                </td>
            </xpath>

            <!-- Custom quantity: abs(quantity) + kWh for fixed_price -->
            <xpath expr="//td[@name='td_quantity']" position="replace">
                <td name="td_quantity" class="text-end custom_td">
                    <span class="text-nowrap">
                        <t t-esc="abs(line.quantity)"/>
                        <t t-if="line.product_id.default_code == 'fixed_price' or line.product_id.default_code == 'anlagen_bonus'">kWh</t>
                    </span>
                </td>
            </xpath>

            <!-- Custom price unit: negative for refunds, currency/kWh or currency suffix -->
            <xpath expr="//td[@name='td_price_unit']" position="replace">
                <td name="td_price_unit"
                    t-attf-class="text-end custom_td {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                    <span class="text-nowrap">
                        <t t-if="o.move_type in ('in_refund', 'in_invoice', 'out_refund')"
                           t-esc="line.price_unit * -1"/>
                        <t t-else="" t-esc="line.price_unit"/>
                        <t t-if="line.product_id.default_code == 'fixed_price' or line.product_id.default_code == 'anlagen_bonus'">€/kWh</t>
                        <t t-else="">€</t>
                    </span>
                </td>
            </xpath>

            <!-- Custom tax display: first 4 chars, text-start alignment -->
            <xpath expr="//td[@name='td_taxes']" position="replace">
                <td name="td_taxes"
                    t-attf-class="text-start {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                    <span t-out="taxes" id="line_tax_ids">Tax 19%</span>
                </td>
            </xpath>

            <!-- Remove payment communication section -->
            <xpath expr="//p[@name='payment_communication']/.." position="replace"/>

            <!-- Hide payment_term for refunds -->
            <xpath expr="//div[@id='payment_term']" position="attributes">
                <attribute name="t-if">o.move_type not in ('in_refund', 'out_refund')</attribute>
            </xpath>

